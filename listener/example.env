# Telegram API credentials (получить на https://my.telegram.org/apps)
API_ID=
API_HASH=

# URL веб-хука для отправки сообщений (например, n8n webhook)
WEBHOOK_URL=

# Список usernames каналов через запятую (без пробелов, с @ или без)
# Пример: @channel1,@channel2,channel3
SOURCE_USERNAMES=

# Имя файла сессии Telegram
SESSION_NAME=arb_session

# Пауза между отправкой POST запросов (в секундах)
POST_PAUSE_SECONDS=1.5
